@page "/rent-payments"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Administrator,PropertyManager,AccountingTeam")]
@inject IRentPaymentService RentPaymentService
@inject ILeaseService LeaseService
@inject AuthenticationStateProvider AuthStateProvider

<PageTitle>Rent Payments - PropertyMS</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">Rent Payments</h4>
    <button class="btn btn-primary" @onclick="OpenForm">+ Record Payment</button>
</div>

@if (!string.IsNullOrEmpty(successMsg))
{
    <div class="alert alert-success alert-dismissible">@successMsg
        <button type="button" class="btn-close" @onclick="() => successMsg = string.Empty"></button>
    </div>
}

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        @if (loading)
        {
            <div class="d-flex justify-content-center py-4"><div class="spinner-border text-primary"></div></div>
        }
        else if (!payments.Any())
        {
            <p class="text-muted p-4 mb-0">No payments recorded yet.</p>
        }
        else
        {
            <table class="table mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Tenant</th><th>Property</th><th>Unit</th><th>Amount</th>
                        <th>Date</th><th>Method</th><th>Outstanding</th><th>Notes</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in payments)
                    {
                        <tr>
                            <td>@p.Lease.Tenant.FullName</td>
                            <td>@p.Lease.Unit.Property.Name</td>
                            <td>@p.Lease.Unit.UnitNumber</td>
                            <td class="text-success fw-semibold">&#8364;@p.Amount.ToString("N2")</td>
                            <td>@p.PaymentDate.ToString("dd MMM yyyy")</td>
                            <td>@p.PaymentMethod</td>
                            <td>
                                @if (p.OutstandingBalance > 0)
                                {
                                    <span class="badge bg-danger">&#8364;@p.OutstandingBalance.ToString("N2")</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">Paid</span>
                                }
                            </td>
                            <td class="text-muted small">@p.Notes</td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>

@if (showForm)
{
    <div class="modal-backdrop show"></div>
    <div class="modal d-block">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Record Rent Payment</h5>
                    <button type="button" class="btn-close" @onclick="() => showForm = false"></button>
                </div>
                <div class="modal-body">
                    @if (!string.IsNullOrEmpty(formError))
                    {
                        <div class="alert alert-danger">@formError</div>
                    }
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">Lease / Tenant *</label>
                            <select class="form-select" @bind="editing.LeaseId" @bind:after="OnLeaseSelected">
                                <option value="0">Select lease...</option>
                                @foreach (var l in activeLeases)
                                {
                                    <option value="@l.Id">@l.Tenant.FullName – @l.Unit.Property.Name @l.Unit.UnitNumber (&#8364;@l.MonthlyRent/mo)</option>
                                }
                            </select>
                        </div>

                        @if (selectedLease != null)
                        {
                            <div class="col-12">
                                <div class="alert alert-info mb-0 py-2">
                                    Current outstanding balance:
                                    <strong>&#8364;@currentBalance.ToString("N2")</strong>
                                </div>
                            </div>
                        }

                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Amount (&#8364;) *</label>
                            <input class="form-control" type="number" @bind="editing.Amount" step="0.01" min="0.01" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Payment Date *</label>
                            <input class="form-control" type="date" @bind="editing.PaymentDate" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Payment Method</label>
                            <select class="form-select" @bind="editing.PaymentMethod">
                                @foreach (var m in Enum.GetValues<PaymentMethod>())
                                {
                                    <option value="@m">@m</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">Notes</label>
                            <input class="form-control" @bind="editing.Notes" />
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button class="btn btn-secondary" @onclick="() => showForm = false">Cancel</button>
                    <button class="btn btn-primary" @onclick="Save">Record Payment</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    bool loading = true, showForm;
    List<RentPayment> payments = new();
    List<Lease> activeLeases = new();
    RentPayment editing = new();
    Lease? selectedLease;
    decimal currentBalance;
    string successMsg = string.Empty, formError = string.Empty;
    int currentUserId;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        int.TryParse(state.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value, out currentUserId);

        payments = await RentPaymentService.GetAllAsync();
        var allLeases = await LeaseService.GetAllAsync();
        activeLeases = allLeases.Where(l => l.Status == LeaseStatus.Active).ToList();
        loading = false;
    }

    void OpenForm()
    {
        editing = new RentPayment { PaymentDate = DateTime.Today, PaymentMethod = PaymentMethod.BankTransfer };
        selectedLease = null;
        currentBalance = 0;
        formError = string.Empty;
        showForm = true;
    }

    async Task OnLeaseSelected()
    {
        selectedLease = activeLeases.FirstOrDefault(l => l.Id == editing.LeaseId);
        if (selectedLease != null)
        {
            currentBalance = await LeaseService.GetOutstandingBalanceAsync(selectedLease.Id);
            if (editing.Amount == 0)
                editing.Amount = selectedLease.MonthlyRent;
        }
    }

    async Task Save()
    {
        if (editing.LeaseId == 0)
        {
            formError = "Please select a lease.";
            return;
        }
        if (editing.Amount <= 0)
        {
            formError = "Payment amount must be greater than zero.";
            return;
        }
        if (editing.PaymentDate > DateTime.Today)
        {
            formError = "Payment date cannot be in the future. Please confirm the date.";
            return;
        }

        editing.RecordedByUserId = currentUserId;
        await RentPaymentService.RecordPaymentAsync(editing);

        showForm = false;
        successMsg = "Payment recorded successfully.";
        payments = await RentPaymentService.GetAllAsync();
    }
}
