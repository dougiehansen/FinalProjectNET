<!-- Confirm Deactivate -->
@if (showConfirm && confirmTarget != null)
{
    <div class="mbk" @onclick="() => { showConfirm = false; }"></div>
    <div class="msh">
        <div class="mbox sm" @onclick:stopPropagation="true">
            <div class="mbdy" style="padding-top:28px;padding-bottom:8px;">
                <div class="conf-ico">⚠️</div>
                <div class="conf-ttl">Deactivate Property?</div>
                <div class="conf-msg">
                    <strong>@confirmTarget.Name</strong> will be marked inactive.<br/>
                    Existing units and leases remain unchanged.
                </div>
            </div>
            <div class="mftr center">
                <button class="btn-cancel" @onclick="() => { showConfirm = false; }">Cancel</button>
                <button class="btn-danger" @onclick="DoDeactivate">Deactivate</button>
            </div>
        </div>
    </div>
}

@code {
    bool loading = true;
    List<Property> properties = new();
    List<Property> filteredProps = new();

    string searchQ = string.Empty;
    string statusFilter = "all";
    string sortBy = "name";

    HashSet<int> expandedProps = new();
    Dictionary<int, string> unitFilters = new();

    string toastMsg = string.Empty, toastClass = string.Empty;

    bool showPropForm, showUnitForm, showConfirm;
    Property editProp = new();
    Unit editUnit = new();
    Property? confirmTarget;
    string propErr = string.Empty, unitErr = string.Empty;

    // Computed
    List<Unit> AllUnits      => properties.Where(p => p.IsActive).SelectMany(p => p.Units.Where(u => u.IsActive)).ToList();
    int  ActivePropCount     => properties.Count(p => p.IsActive);
    int  OccupiedCount       => AllUnits.Count(u => u.IsOccupied);
    int  VacantCount         => AllUnits.Count(u => !u.IsOccupied);
    int  OccRate             => AllUnits.Count > 0 ? (int)Math.Round(OccupiedCount * 100.0 / AllUnits.Count) : 0;
    decimal TotalRev         => AllUnits.Where(u => u.IsOccupied).Sum(u => u.MonthlyRent);

    protected override async Task OnInitializedAsync()
    {
        properties = await PropertyService.GetAllAsync();
        ApplyFilters();
        loading = false;
        if (filteredProps.Any()) expandedProps.Add(filteredProps[0].Id);
    }

    // Search / filter / sort
    void OnSearch(ChangeEventArgs e)
    {
        searchQ = e.Value?.ToString() ?? string.Empty;
        ApplyFilters();
    }

    void OnSortChange(ChangeEventArgs e)
    {
        sortBy = e.Value?.ToString() ?? "name";
        ApplyFilters();
    }

    void FilterAll()      { statusFilter = "all";      ApplyFilters(); }
    void FilterActive()   { statusFilter = "active";   ApplyFilters(); }
    void FilterInactive() { statusFilter = "inactive"; ApplyFilters(); }

    void ApplyFilters()
    {
        var q = searchQ.Trim();
        IEnumerable<Property> r = properties;

        if (statusFilter == "active")   r = r.Where(p => p.IsActive);
        if (statusFilter == "inactive") r = r.Where(p => !p.IsActive);

        if (!string.IsNullOrEmpty(q))
            r = r.Where(p =>
                p.Name.Contains(q, StringComparison.OrdinalIgnoreCase) ||
                p.City.Contains(q, StringComparison.OrdinalIgnoreCase) ||
                p.Address.Contains(q, StringComparison.OrdinalIgnoreCase) ||
                p.Units.Any(u => u.UnitNumber.Contains(q, StringComparison.OrdinalIgnoreCase) ||
                                 u.Type.Contains(q, StringComparison.OrdinalIgnoreCase)));

        filteredProps = (sortBy switch
        {
            "city"  => r.OrderBy(p => p.City).ThenBy(p => p.Name),
            "units" => r.OrderByDescending(p => p.Units.Count(u => u.IsActive)),
            "occ"   => r.OrderByDescending(p => p.Units.Count(u => u.IsActive && u.IsOccupied)),
            "rev"   => r.OrderByDescending(p => p.Units.Where(u => u.IsActive && u.IsOccupied).Sum(u => u.MonthlyRent)),
            _       => r.OrderBy(p => p.Name),
        }).ToList();
    }

    List<Unit> FilterUnits(List<Unit> units, string f) => f switch
    {
        "occupied" => units.Where(u =>  u.IsOccupied).ToList(),
        "vacant"   => units.Where(u => !u.IsOccupied).ToList(),
        _          => units,
    };

    // Expand / collapse
    void ToggleExpand(int id) { if (!expandedProps.Remove(id)) expandedProps.Add(id); }
    void ExpandAll()   { foreach (var p in filteredProps) expandedProps.Add(p.Id); }
    void CollapseAll() { expandedProps.Clear(); }

    void SetUnitFilter(int propId, string f) => unitFilters[propId] = f;

    // Toast
    async Task ShowToast(string msg, bool ok = true)
    {
        toastMsg = msg; toastClass = ok ? "ok" : "err";
        StateHasChanged();
        await Task.Delay(3200);
        toastMsg = string.Empty;
        StateHasChanged();
    }

    // Property CRUD
    void OpenPropertyForm(Property? p = null)
    {
        editProp = p != null
            ? new Property { Id = p.Id, Name = p.Name, Address = p.Address, City = p.City, State = p.State, ZipCode = p.ZipCode, ContactPhone = p.ContactPhone, ContactEmail = p.ContactEmail, IsActive = p.IsActive }
            : new Property();
        propErr = string.Empty;
        showPropForm = true;
    }

    async Task SaveProperty()
    {
        if (string.IsNullOrWhiteSpace(editProp.Name) || string.IsNullOrWhiteSpace(editProp.Address))
        {
            propErr = "Property name and address are required.";
            return;
        }
        bool isNew = editProp.Id == 0;
        if (isNew) await PropertyService.CreateAsync(editProp);
        else       await PropertyService.UpdateAsync(editProp);

        showPropForm = false;
        properties = await PropertyService.GetAllAsync();
        ApplyFilters();
        if (isNew)
        {
            var created = filteredProps.FirstOrDefault(p => p.Name == editProp.Name);
            if (created != null) expandedProps.Add(created.Id);
        }
        await ShowToast(isNew ? "Property created." : "Property updated.");
    }

    void ConfirmDeactivate(Property p) { confirmTarget = p; showConfirm = true; }

    async Task DoDeactivate()
    {
        if (confirmTarget == null) return;
        await PropertyService.DeactivateAsync(confirmTarget.Id);
        var name = confirmTarget.Name;
        showConfirm = false; confirmTarget = null;
        properties = await PropertyService.GetAllAsync();
        ApplyFilters();
        await ShowToast($"\"{name}\" deactivated.");
    }

    // Unit CRUD
    void AddUnit(int propertyId)
    {
        editUnit = new Unit { PropertyId = propertyId };
        unitErr = string.Empty;
        showUnitForm = true;
    }

    void EditUnit(Unit u)
    {
        editUnit = new Unit
        {
            Id = u.Id, PropertyId = u.PropertyId, UnitNumber = u.UnitNumber, Type = u.Type,
            FloorArea = u.FloorArea, Bedrooms = u.Bedrooms, Bathrooms = u.Bathrooms,
            MonthlyRent = u.MonthlyRent, Amenities = u.Amenities, IsOccupied = u.IsOccupied, IsActive = u.IsActive
        };
        unitErr = string.Empty;
        showUnitForm = true;
    }

    async Task SaveUnit()
    {
        if (string.IsNullOrWhiteSpace(editUnit.UnitNumber) || editUnit.MonthlyRent <= 0)
        {
            unitErr = "Unit number and a positive monthly rent are required.";
            return;
        }
        bool isNew = editUnit.Id == 0;
        if (isNew) await UnitService.CreateAsync(editUnit);
        else       await UnitService.UpdateAsync(editUnit);

        showUnitForm = false;
        properties = await PropertyService.GetAllAsync();
        ApplyFilters();
        expandedProps.Add(editUnit.PropertyId);
        await ShowToast(isNew ? "Unit added." : "Unit updated.");
    }
}
