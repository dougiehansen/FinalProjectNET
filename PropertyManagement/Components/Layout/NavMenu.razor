<div class="sidebar-inner">

    <!-- Brand -->
    <div class="sidebar-brand">
        <img src="/images/keyport-icon.svg" alt="KeyPort" class="brand-icon-img" />
        <span class="brand-name">Key<span>Port</span></span>
    </div>

    <AuthorizeView>
        <Authorized>

            <nav class="sidebar-nav">

                <NavLink class="nav-item" href="/" Match="NavLinkMatch.All">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/>
                        <rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/>
                    </svg>
                    <span>Dashboard</span>
                </NavLink>

                <AuthorizeView Roles="Administrator,PropertyManager" Context="pmCtx">
                    <div class="nav-section">Properties</div>
                    <NavLink class="nav-item" href="/properties">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                            <polyline points="9,22 9,12 15,12 15,22"/>
                        </svg>
                        <span>Properties &amp; Units</span>
                    </NavLink>
                    <NavLink class="nav-item" href="/tenants">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/>
                            <circle cx="9" cy="7" r="4"/>
                            <path d="M23 21v-2a4 4 0 00-3-3.87M16 3.13a4 4 0 010 7.75"/>
                        </svg>
                        <span>Tenants</span>
                    </NavLink>
                    <NavLink class="nav-item" href="/leases">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/>
                            <polyline points="14,2 14,8 20,8"/>
                            <line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/>
                        </svg>
                        <span>Leases</span>
                    </NavLink>
                </AuthorizeView>

                <AuthorizeView Roles="Administrator,PropertyManager,AccountingTeam" Context="acctCtx">
                    <div class="nav-section">Finance</div>
                    <NavLink class="nav-item" href="/rent-payments">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <rect x="1" y="4" width="22" height="16" rx="2" ry="2"/>
                            <line x1="1" y1="10" x2="23" y2="10"/>
                        </svg>
                        <span>Rent Payments</span>
                    </NavLink>
                </AuthorizeView>

                <div class="nav-section">Maintenance</div>
                <NavLink class="nav-item" href="/maintenance">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z"/>
                    </svg>
                    <span>Work Orders</span>
                </NavLink>

                <AuthorizeView Roles="Administrator,PropertyManager,AccountingTeam" Context="rptCtx">
                    <div class="nav-section">Analytics</div>
                    <NavLink class="nav-item" href="/reports">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="18" y1="20" x2="18" y2="10"/>
                            <line x1="12" y1="20" x2="12" y2="4"/>
                            <line x1="6" y1="20" x2="6" y2="14"/>
                        </svg>
                        <span>Reports</span>
                    </NavLink>
                </AuthorizeView>

                <AuthorizeView Roles="Administrator" Context="adminCtx">
                    <div class="nav-section">Admin</div>
                    <NavLink class="nav-item" href="/admin/users">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="8" r="4"/>
                            <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
                            <circle cx="19" cy="14" r="3"/>
                            <path d="M19 11v1M19 17v1M16.27 12.5l.87.5M21.87 15l-.87.5M16.27 15.5l.87-.5M21.87 13l-.87-.5"/>
                        </svg>
                        <span>User Management</span>
                    </NavLink>
                </AuthorizeView>

            </nav>

            <!-- User footer -->
            <div class="sidebar-user">
                <div class="user-avatar">
                    @(context.User.Identity?.Name is { Length: > 0 } n ? n[0].ToString().ToUpper() : "U")
                </div>
                <div class="user-info">
                    <div class="user-name">@context.User.Identity?.Name</div>
                    <div class="user-role">@context.User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</div>
                </div>
                <a href="/Account/Logout" class="signout-btn" title="Sign out">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/>
                        <polyline points="16,17 21,12 16,7"/>
                        <line x1="21" y1="12" x2="9" y2="12"/>
                    </svg>
                </a>
            </div>

        </Authorized>
    </AuthorizeView>

</div>
