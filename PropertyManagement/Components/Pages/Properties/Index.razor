                        </div>
                    </div>
                    <div class="frow">
                        <div class="fg">
                            <label class="fl">Street Address *</label>
                            <input class="fi" @bind="editProp.Address" placeholder="123 Main Street" />
                        </div>
                    </div>
                    <div class="frow c3">
                        <div class="fg">
                            <label class="fl">City</label>
                            <input class="fi" @bind="editProp.City" placeholder="Dublin" />
                        </div>
                        <div class="fg">
                            <label class="fl">County / State</label>
                            <input class="fi" @bind="editProp.State" placeholder="Co. Dublin" />
                        </div>
                        <div class="fg">
                            <label class="fl">Eircode</label>
                            <input class="fi" @bind="editProp.ZipCode" placeholder="D01 AB12" />
                        </div>
                    </div>
                    <div class="frow c2">
                        <div class="fg">
                            <label class="fl">Contact Phone</label>
                            <input class="fi" @bind="editProp.ContactPhone" placeholder="+353 1 234 5678" />
                        </div>
                        <div class="fg">
                            <label class="fl">Contact Email</label>
                            <input class="fi" type="email" @bind="editProp.ContactEmail" placeholder="manager@example.com" />
